# =============================================================================
# BanSos — comprehensive .gitignore
# Frontend: React + Vite + TypeScript
# Backend:  Python + FastAPI (bansos backend/)
# Database: Supabase
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets & environment files (NEVER commit)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template
*.pem
*.key
*.p12
secrets/
credentials.json
service-account*.json

# Backend-specific env (folder name contains a space)
bansos backend/.env
bansos backend/.env.*

# -----------------------------------------------------------------------------
# Node / frontend dependencies & build output
# -----------------------------------------------------------------------------
node_modules/
jspm_packages/
web_modules/

dist/
dist-ssr/
build/
out/
.next/
.nuxt/
.output/
.svelte-kit/
**/.vitepress/dist
**/.vitepress/cache
.docusaurus/
.serverless/

# Vite
.vite/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# TypeScript
*.tsbuildinfo

# Package manager caches
.npm
.pnpm-store
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.yarn-integrity

# Test / coverage (frontend)
coverage/
*.lcov
.nyc_output
lib-cov/
.vscode-test

# Lint / formatter cache
.eslintcache
.stylelintcache

# Parcel / bundler caches
.cache/
.parcel-cache/
.fusebox/
.grunt/
.temp/
.temp

# -----------------------------------------------------------------------------
# Python / backend (bansos backend/)
# -----------------------------------------------------------------------------
# Virtual environments (any location)
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/
bansos backend/venv/

# Bytecode & compiled Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyo

# Distribution / packaging
.Python
*.egg
*.egg-info/
.eggs/
pip-wheel-metadata/
pip-log.txt
MANIFEST
*.manifest
*.spec
build/
develop-eggs/
downloads/
eggs/
parts/
sdist/
var/
wheels/
share/python-wheels/
.installed.cfg

# Test & type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.tox/
.nox/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/

# Jupyter
.ipynb_checkpoints/

# pyenv / virtualenv tools
.python-version
.pdm-python

# -----------------------------------------------------------------------------
# Supabase local development
# -----------------------------------------------------------------------------
.supabase/
supabase/.branches/
supabase/.temp/

# -----------------------------------------------------------------------------
# Logs & runtime
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
pids/
*.pid
*.seed
*.pid.lock

# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Thumbs.db:encryptable
Desktop.ini
$RECYCLE.BIN/
__MACOSX/

# -----------------------------------------------------------------------------
# Editors & IDEs
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.iml
*.ipr
*.iws
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# Cursor (local AI/editor state — optional to keep out of repo)
.cursor/

# -----------------------------------------------------------------------------
# Misc temporary / local-only files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
*.orig
*.local

# Lock-wscript / legacy
.lock-wscript
bower_components/
.node_repl_history
*.tgz
.tern-port

# DynamoDB / Firebase local
.dynamodb/
.firebase/

# Large local data dumps (regenerate via backend scripts — uncomment if needed)
# bansos backend/datasource/raw/
# bansos backend/datasource/clean/
